{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",

    "rootDir": "./src",
    "outDir": "./dist",

    "strict": true,

    "declaration": true,
    "declarationMap": true,

    "sourceMap": true,

    "esModuleInterop": true,

    "forceConsistentCasingInFileNames": true,

    "skipLibCheck": true,

    "resolveJsonModule": true,

    "isolatedModules": true,

    "noImplicitOverride": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true
  },

  "include": ["src"],

  "exclude": [
    "node_modules",
    "dist",
    "tests"
  ]
}